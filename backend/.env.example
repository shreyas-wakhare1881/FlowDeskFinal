# Backend Environment Variables
# Copy this file to .env and fill in your values

# PostgreSQL connection string (used by Prisma migrations/studio)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/flowdesk"

# Individual DB params (used by prisma.service.ts at runtime)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=flowdesk
DB_USER=postgres
DB_PASSWORD=your_password_here

# Port for the NestJS API server (default: 3001)
PORT=3001

# Allowed frontend origin for CORS (default: http://localhost:3000)
FRONTEND_URL="http://localhost:3000"

# JWT secret key — change this to a strong random string in production
JWT_SECRET="your-super-secret-jwt-key-here"
