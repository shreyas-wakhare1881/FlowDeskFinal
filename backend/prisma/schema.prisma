// PM Tool Database Schema
// Matches exactly with current localStorage structure
// Created: March 17, 2026
// Updated: March 30, 2026 — Phase 1 RBAC: added roles, modules, permissions, role_permissions, user_roles

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// USERS — Authentication
// ============================================

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // ── RBAC relations (Phase 1) ──────────────────────────────────────
  userRoles         UserRole[]           // roles this user holds per project
  assignedRoles     UserRole[]  @relation("AssignedByUser")  // roles this user assigned to others
  grantedPerms      RolePermission[]     // permission mappings this user approved
  createdProjects   Project[]   @relation("ProjectCreator")  // projects this user created

  @@index([email])
  @@map("users")
}

// ============================================
// GLOBAL VIEW - PROJECT MANAGEMENT
// ============================================

model Project {
  id                  String    @id @default(uuid())
  projectID           String    @unique         // PRJ-001, PRJ-002, etc.
  projectName         String
  projectDescription  String?
  status              String                    // 'todo', 'in-progress', 'completed', 'overdue'
  statusLabel         String                    // 'To Do', 'In Progress', etc.
  priority            String                    // 'critical', 'medium', 'low'
  category            String                    // 'General', 'Design', etc.
  
  // Dates
  createdDate         DateTime  @default(now())
  assignedDate        DateTime
  dueDate             DateTime?
  completedDate       DateTime?
  
  // Team Info (basic)
  teamID              String
  teamName            String
  assigneeID          String
  assigneeName        String
  assigneeAvatar      String
  assigneeAvatarColor String
  
  // New project-level fields
  isRecurring         Boolean   @default(false)
  recurringFrequency  String?

  // ── RBAC: project ownership (Phase 1) ────────────────────────────
  createdById         String?                           // nullable for backward compat with existing projects
  createdBy           User?     @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: SetNull)

  // Relations
  teamLead            TeamLead?
  teamMembers         TeamMember[]
  metrics             Metrics?
  tags                ProjectTag[]
  teams               Team[]
  tasks               Task[]
  userRoles           UserRole[]   // members + their roles in this project
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([status])
  @@index([priority])
  @@index([teamID])
  @@map("projects")
}

model ProjectTag {
  id        String  @id @default(uuid())
  tag       String

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_tags")
}

model TeamLead {
  id          String   @id @default(uuid())
  leadId      String   // USER-001
  name        String   // 'You'
  avatar      String   // 'YU'
  avatarColor String   // '#4361ee'
  
  projectId   String   @unique
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@map("team_leads")
}

model TeamMember {
  id          String   @id @default(uuid())
  memberId    String   // USER-001, USER-002
  name        String   // 'Rahul Kumar', 'Sneha Patel'
  avatar      String   // 'RK', 'SP'
  avatarColor String   // '#4361ee'
  role        String   // 'Owner', 'Team Member'
  status      String   @default("online") // 'online', 'offline'
  
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@map("team_members")
}

model Metrics {
  id                    String   @id @default(uuid())
  completionPercentage  Int      @default(0)
  tasksTotal            Int      @default(0)
  tasksCompleted        Int      @default(0)
  tasksInProgress       Int      @default(0)
  tasksOverdue          Int      @default(0)
  
  projectId             String   @unique
  project               Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@map("metrics")
}

// ============================================
// WORKSPACE VIEW - TASK MANAGEMENT
// ============================================

model Task {
  id                   String    @id @default(uuid())
  taskID               String    @unique         // TASK-101, TASK-102
  taskName             String
  taskDescription      String?
  status               String    @default("todo") // 'todo', 'in-progress', 'completed', 'overdue'
  priority             String                     // 'critical', 'medium', 'low'
  isRecurring          Boolean   @default(false)
  recurringFrequency   String?                    // 'Daily', 'Weekly', etc.

  createdAt            DateTime  @default(now())
  dueDate              DateTime
  completedDate        DateTime?

  // Links back to the project this task belongs to
  projectId            String
  project              Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Assignees (simple string list stored as JSON-like relation)
  assignees            TaskAssignee[]

  @@index([projectId])
  @@index([status])
  @@index([dueDate])
  @@map("tasks")
}

model TaskAssignee {
  id          String @id @default(uuid())
  name        String
  avatar      String @default("")
  avatarColor String @default("#4361ee")

  taskId      String
  task        Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_assignees")
}

// ============================================
// TEAMS — First-class entities per project
// ============================================

model Team {
  id        String           @id @default(uuid())
  teamID    String           @unique     // e.g. BCT-001, TEAM-001
  teamName  String
  createdAt DateTime         @default(now())

  projectId String
  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  members   TeamParticipant[]

  @@map("teams")
}

model TeamParticipant {
  id     String @id @default(uuid())
  name   String
  avatar String
  color  String @default("#4361ee")

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("team_participants")
}

// ============================================
// RBAC — Phase 1 Migration (March 30, 2026)
// Architecture: User → Role (per Project) → Permission → Module
// All tables are ADDITIVE — existing tables are unchanged except projects.createdById
// ============================================

// ── 1. Role definitions ───────────────────────────────────────────────────────
// Predefined: SuperAdmin, Manager, Developer, Client
// These are templates — actual access is determined by role_permissions mapping

model Role {
  id          String   @id @default(uuid())
  name        String   @unique    // 'SuperAdmin', 'Manager', 'Developer', 'Client'
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

// ── 2. Module definitions ─────────────────────────────────────────────────────
// Represents functional areas of the app that can be access-controlled
// Predefined: TASKS, PROJECTS, TEAMS, REPORTS, COMMENTS, USERS

model Module {
  id          String   @id @default(uuid())
  name        String   @unique    // 'TASKS', 'PROJECTS', 'TEAMS', etc.
  description String?
  createdAt   DateTime @default(now())

  // Relations
  permissions Permission[]

  @@map("modules")
}

// ── 3. Permission definitions ─────────────────────────────────────────────────
// Each permission = one action on one module (e.g. CREATE_TASK = CREATE on TASKS)
// name must follow convention: {ACTION}_{MODULE_SUBJECT}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique    // e.g. 'CREATE_TASK', 'VIEW_PROJECT'
  action      String              // 'CREATE' | 'READ' | 'UPDATE' | 'DELETE' | 'MANAGE'
  description String?
  createdAt   DateTime @default(now())

  // FK to module
  moduleId    String
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  // Relations
  rolePermissions RolePermission[]

  @@index([moduleId])
  @@map("permissions")
}

// ── 4. Role ↔ Permission mapping (global) ────────────────────────────────────
// Defines which permissions a role grants.
// This is NOT project-scoped — if Manager has CREATE_TASK, it applies in all projects.

model RolePermission {
  roleId       String
  permissionId String
  grantedAt    DateTime @default(now())

  // Audit: who configured this mapping (nullable — seeded programmatically)
  grantedById  String?
  grantedBy    User?       @relation(fields: [grantedById], references: [id], onDelete: SetNull)

  // Relations
  role         Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ── 5. User ↔ Role ↔ Project mapping (THE CORE TABLE) ────────────────────────
// Assigns a user a specific role within a specific project.
// One user can appear multiple times — once per project they belong to.
// Composite PK ensures a user can only hold ONE role per project.

model UserRole {
  userId     String
  roleId     String
  projectId  String
  assignedAt DateTime @default(now())

  // Audit: who made the assignment (nullable — backfilled programmatically)
  assignedById String?
  assignedBy   User?    @relation("AssignedByUser", fields: [assignedById], references: [id], onDelete: SetNull)

  // Relations
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([userId, roleId, projectId])
  @@unique([userId, projectId])  // enforces one role per user per project at DB level
  @@index([userId, projectId])   // fast lookup: "what is this user's role in this project?"
  @@map("user_roles")
}
